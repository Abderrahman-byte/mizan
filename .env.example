# Copy to ./.env (repo root). Docker Compose auto-loads this file and feeds the
# values into the containers. All keys have defaults in docker-compose.dev.yml, so
# ./.env is optional — use it to override defaults (e.g. a real JWT_SECRET).

# Database connection parts (the async SQLAlchemy URL is assembled from these).
# Inside Docker the host is the `db` service on its in-network port 5432.
DB_PORT=5432
DB_USER=mizan
DB_PASSWORD=mizan
DB_NAME=mizan

LOG_LEVEL=INFO

# Browser origins allowed to call the API (comma-separated). Defaults cover the Vite
# dev server (docker host :5174, bare-metal :5173). Prod is same-origin behind nginx.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend — backend API base URL as seen by the BROWSER (the backend's host port).
VITE_API_URL=http://localhost:8088/api

# Auth secret — placeholder; required (no default) in production.
# Token TTLs are NOT here: they're hardcoded in the compose files as app constants.
JWT_SECRET=change-me
